{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "perla.rtp.storyboards.schema.v1",
  "title": "PERLA1 RTP Storyboards",
  "type": "object",
  "required": [
    "schemaVersion",
    "status",
    "runtimeBasePath",
    "storyboards"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string"
    },
    "runtimeLoaded": {
      "type": "boolean"
    },
    "runtimeBasePath": {
      "type": "string"
    },
    "storyboards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "eventId",
          "loadPolicy",
          "trigger",
          "afterComplete",
          "panels"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "eventId": {
            "type": "string"
          },
          "sourceType": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "loadPolicy": {
            "type": "string"
          },
          "textBakedIntoImage": {
            "type": "boolean"
          },
          "trigger": {
            "type": "string"
          },
          "afterComplete": {
            "type": "string"
          },
          "sourceDimensions": {
            "type": "object",
            "required": [
              "width",
              "height"
            ],
            "properties": {
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          },
          "panels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id",
                "order",
                "title",
                "caption",
                "path",
                "width",
                "height",
                "format",
                "durationMs",
                "sourceRect"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "order": {
                  "type": "integer",
                  "minimum": 0
                },
                "title": {
                  "type": "string"
                },
                "caption": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "width": {
                  "type": "integer",
                  "minimum": 1
                },
                "height": {
                  "type": "integer",
                  "minimum": 1
                },
                "format": {
                  "type": "string",
                  "enum": [
                    "webp",
                    "avif",
                    "png",
                    "jpg",
                    "jpeg"
                  ]
                },
                "durationMs": {
                  "type": "integer",
                  "minimum": 500
                },
                "sourceRect": {
                  "type": "object",
                  "required": [
                    "x",
                    "y",
                    "width",
                    "height"
                  ],
                  "properties": {
                    "x": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "y": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "width": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "height": {
                      "type": "integer",
                      "minimum": 1
                    }
                  },
                  "additionalProperties": false
                },
                "readerCaption": {
                  "type": "string"
                },
                "beatType": {
                  "type": "string"
                },
                "focusCharacter": {
                  "type": "string"
                },
                "recommendedDurationMs": {
                  "type": "integer",
                  "minimum": 500
                },
                "transition": {
                  "type": "string"
                },
                "continuityBefore": {
                  "type": "string"
                },
                "continuityAfter": {
                  "type": "string"
                },
                "accessibilityAlt": {
                  "type": "string"
                },
                "motion": {
                  "type": "object",
                  "required": [
                    "type"
                  ],
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "intensity": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                },
                "audioCue": {
                  "type": "object",
                  "required": [
                    "type"
                  ],
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "intensity": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "readerMode": {
            "type": "string"
          },
          "storytellingNotes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
