      "speakerId": "nina_ciottolo",
      "eventId": "event.challenge.nina_ciottolo",
      "lineType": "event",
      "portraitPolicy": "main_character_portrait",
      "line": "Va bene, mi unisco. Ma se Imperio tassa anche l'acqua fredda, lo asciugo io.",
